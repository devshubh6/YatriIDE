<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary"
    tools:context=".MainActivity">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/primary_dark"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚀 Yatri IDE"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/accent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0 | Android Code Editor"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Code Editor Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📝 Code Editor"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/accent"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/codeEditor"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:hint="@string/hint_code"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:background="@drawable/editor_bg"
            android:padding="12dp"
            android:textSize="13sp"
            android:typeface="monospace"
            android:inputType="textMultiLine"
            android:gravity="top|left"
            android:scrollbars="vertical" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Control Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center"
        android:background="@color/primary_dark">

        <Button
            android:id="@+id/btnCompile"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="@string/btn_compile"
            android:textSize="12sp"
            android:background="@drawable/button_bg_primary"
            android:textColor="@color/primary"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="@string/btn_save"
            android:textSize="12sp"
            android:background="@drawable/button_bg_secondary"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnOpen"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="@string/btn_open"
            android:textSize="12sp"
            android:background="@drawable/button_bg_secondary"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="@string/btn_clear"
            android:textSize="12sp"
            android:background="@drawable/button_bg_danger"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Console Output Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.8"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💻 Console Output"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/accent"
            android:layout_marginBottom="8dp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <EditText
                android:id="@+id/consoleOutput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_console"
                android:textColor="@color/success"
                android:textColorHint="@color/text_secondary"
                android:background="@drawable/console_bg"
                android:padding="8dp"
                android:textSize="11sp"
                android:typeface="monospace"
                android:inputType="textMultiLine"
                android:editable="false"
                android:gravity="top|left" />

        </ScrollView>

    </LinearLayout>

</LinearLayout>
