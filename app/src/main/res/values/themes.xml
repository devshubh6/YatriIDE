<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.YatriIDE" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent</item>
        <item name="colorError">@color/error</item>

        <!-- Customize your theme here. -->
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:windowBackground">@color/primary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="EditorStyle" parent="Theme.YatriIDE">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:background">@drawable/editor_bg</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:padding">12dp</item>
    </style>

    <style name="ConsoleStyle" parent="Theme.YatriIDE">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/success</item>
        <item name="android:background">@drawable/console_bg</item>
        <item name="android:padding">8dp</item>
    </style>

    <style name="ButtonPrimaryStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/button_bg_primary</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:padding">12dp</item>
        <item name="android:layout_margin">4dp</item>
    </style>

    <style name="ButtonSecondaryStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/button_bg_secondary</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:padding">12dp</item>
        <item name="android:layout_margin">4dp</item>
    </style>

    <style name="ButtonDangerStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/button_bg_danger</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:padding">12dp</item>
        <item name="android:layout_margin">4dp</item>
    </style>

    <style name="HeaderStyle" parent="Theme.YatriIDE">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/accent</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
